# ============================================================
# Configurações do ambiente Laravel
# Copie este arquivo para .env e ajuste conforme necessário
# ============================================================

APP_NAME="SIGE - Sistema de Gestão de Estoque"
APP_ENV=local
APP_KEY=                         # Gere com: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

# ---- Configuração do banco de dados ----
# Os valores aqui devem bater com o docker-compose.yml
DB_CONNECTION=mysql
DB_HOST=banco                    # Nome do serviço no docker-compose
DB_PORT=3306
DB_DATABASE=sige
DB_USERNAME=sige_user
DB_PASSWORD=sige_pass

# ---- Configuração de sessão e cache ----
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=sync

# ---- Configuração do Sanctum (autenticação da API) ----
# Domínios que podem fazer requisições autenticadas
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173

# ---- Configuração de CORS ----
# Permite que o frontend Vue.js (porta 3000) acesse o backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Configuração de log ----
LOG_CHANNEL=stack
LOG_LEVEL=debug
